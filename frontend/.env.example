# Frontend environment variables. Copied to .env.local during dev.
# Only variables prefixed with VITE_ are exposed to the bundle; everything
# else stays server-side. See Vite docs: https://vitejs.dev/guide/env-and-mode

# ─── API endpoint ───────────────────────────────────────────
# Override only when:
#   - the FastAPI service runs on a different host/port
#   - you put a reverse proxy in front (e.g. Caddy / nginx on :443)
# When unset, _client.ts falls back to:
#   - http://127.0.0.1:8000 in dev (vite serves on :5173)
#   - same origin in production builds
VITE_API_BASE_URL=

# ─── Reserved for future use ─────────────────────────────────
# VITE_DEV_BANNER=true         # show a corner "DEV" badge so you never
#                              # mistake a dev server for production
# VITE_SSE_HEARTBEAT_SECONDS=10
# VITE_FEATURE_FLAGS=...        # comma-separated flags (e.g. "risk_v2,bot")
