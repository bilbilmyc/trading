APP_ENV=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
FRONTEND_STATIC_DIR=static

DEFAULT_EXCHANGE=okx
DEFAULT_SYMBOL=BTC-USDT

# Keep false until you have verified API keys, symbols, order sizing, and risk limits.
ENABLE_LIVE_TRADING=false

OKX_ENABLED=true
OKX_SWAP_ENABLED=true
OKX_USE_TESTNET=true
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

BINANCE_ENABLED=true
BINANCE_USDM_ENABLED=true
BINANCE_USE_TESTNET=true
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

MAX_POSITION_SIZE=1
MAX_POSITION_VALUE=1000
STOP_LOSS_PCT=0.05
TAKE_PROFIT_PCT=0.10
MAX_DAILY_LOSS=100
MAX_DRAWDOWN_PCT=0.20
MAX_ORDERS_PER_MINUTE=5
