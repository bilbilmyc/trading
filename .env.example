APP_ENV=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
FRONTEND_STATIC_DIR=static
SQLITE_PATH=data/trading.sqlite3

DEFAULT_EXCHANGE=binance_usdm
DEFAULT_SYMBOL=BTCUSDT

# ─── 实盘开关 ──────────────────────────────────────────────
# Set to true ONLY after:
#   - testnet API keys are verified
#   - symbols, order sizing, and risk limits have been validated
#   - paper/signal mode has been running without unexpected behavior
ENABLE_LIVE_TRADING=false

# ─── 订单同步 ──────────────────────────────────────────────
ORDER_SYNC_INTERVAL_SECONDS=10
POSITION_SYNC_INTERVAL_SECONDS=15

# ─── 监控告警 ──────────────────────────────────────────────
MONITOR_CHECK_INTERVAL_SECONDS=30
MONITOR_MAX_ALERTS=100

# ─── AI 大模型分析 ─────────────────────────────────────────
# 用于 POST /api/v1/ai/analyze 端点。支持任意 OpenAI 兼容 API。
# 留空时分析端点仍可用，但返回 hold / "未配置 API Key"
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048
LLM_REQUEST_TIMEOUT=30

# ─── LLM 策略（D→B→A）─────────────────────────────────────
# 单笔默认下单金额（USDT），防止全仓
LLM_DEFAULT_ORDER_AMOUNT=50

BINANCE_ENABLED=true
BINANCE_USDM_ENABLED=true
BINANCE_USE_TESTNET=true
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

BITGET_ENABLED=true
BITGET_USDT_FUTURES_ENABLED=true
BITGET_USE_TESTNET=true
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=

OKX_ENABLED=true
OKX_SWAP_ENABLED=true
OKX_USE_TESTNET=true
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

MAX_POSITION_SIZE=1
MAX_POSITION_VALUE=1000
STOP_LOSS_PCT=0.05
TAKE_PROFIT_PCT=0.10
MAX_DAILY_LOSS=100
MAX_DRAWDOWN_PCT=0.20
MAX_ORDERS_PER_MINUTE=5

# ─── LLM 决策白名单（可选） ──────────────────────────────
# Restricts which symbols the LLM may decide to trade on. Empty (default)
# means no restriction — the LLM can decide on any symbol it sees.
# Set as a JSON list to limit, e.g.:
#   LLM_ALLOWED_SYMBOLS=["BTCUSDT","ETHUSDT","SOLUSDT"]
LLM_ALLOWED_SYMBOLS=

# ─── API 鉴权（可选） ─────────────────────────────────────
# Set this to require `Authorization: Bearer <key>` on dangerous endpoints
# (kill-switch, order placement, position close, etc.). Leave empty to keep
# the existing localhost-only workflow where any local client can call the API.
# Generate a random value, e.g. `python -c "import secrets; print(secrets.token_urlsafe(32))"`
AUTH_API_KEY=
