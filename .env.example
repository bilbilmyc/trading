APP_ENV=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
FRONTEND_STATIC_DIR=static
SQLITE_PATH=data/trading.sqlite3
# DuckDB 元数据目录与不可变 Parquet 行情文件目录
MARKET_DATA_CATALOG_PATH=data/market_data.duckdb
MARKET_DATA_PARQUET_DIR=data/market_data

DEFAULT_EXCHANGE=binance_usdm
DEFAULT_SYMBOL=BTCUSDT

# ─── 实盘开关 ──────────────────────────────────────────────
# Set to true ONLY after:
#   - testnet API keys are verified
#   - symbols, order sizing, and risk limits have been validated
#   - paper/signal mode has been running without unexpected behavior
ENABLE_LIVE_TRADING=false

# ─── 订单同步 ──────────────────────────────────────────────
ORDER_SYNC_INTERVAL_SECONDS=10
POSITION_SYNC_INTERVAL_SECONDS=15

# ─── 监控告警 ──────────────────────────────────────────────
MONITOR_CHECK_INTERVAL_SECONDS=30
MONITOR_MAX_ALERTS=100

# ─── AI 大模型分析 ─────────────────────────────────────────
# 用于 POST /api/v1/ai/analyze 端点。支持任意 OpenAI 兼容 API。
# 留空时分析端点仍可用，但返回 hold / "未配置 API Key"
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048
LLM_REQUEST_TIMEOUT=30
# 策略实例级调用保护：缓存命中不会受影响；0 表示不做节流。
LLM_MIN_REQUEST_INTERVAL_SECONDS=0
# 连续真实 provider 调用失败次数达到阈值后，进入冷却期。
LLM_CIRCUIT_FAILURE_THRESHOLD=3
LLM_CIRCUIT_COOLDOWN_SECONDS=60

# ─── LLM 策略（D→B→A）─────────────────────────────────────
# 单笔默认下单金额（USDT），防止全仓
LLM_DEFAULT_ORDER_AMOUNT=50

BINANCE_ENABLED=true
BINANCE_USDM_ENABLED=true
BINANCE_USE_TESTNET=true
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

BITGET_ENABLED=true
BITGET_USDT_FUTURES_ENABLED=true
BITGET_USE_TESTNET=true
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=

OKX_ENABLED=true
OKX_SWAP_ENABLED=true
OKX_USE_TESTNET=true
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# ─── 统一预交易风控 ──────────────────────────────────────────
MAX_POSITION_SIZE=1
MAX_POSITION_VALUE=1000
# 跨现货、合约和受控 Bot 的单日实际下单名义金额上限；0 = 关闭。
MAX_DAILY_ORDER_NOTIONAL=5000
# 合约下单最大杠杆；0 = 不限制（建议始终设置正数）。
MAX_LEVERAGE=5
STOP_LOSS_PCT=0.05
TAKE_PROFIT_PCT=0.10
MAX_DAILY_LOSS=100
MAX_DRAWDOWN_PCT=0.20
MAX_ORDERS_PER_MINUTE=5
# 连续亏损暂停阈值；0 = 关闭。需由成交结果接入持续更新。
MAX_CONSECUTIVE_LOSSES=0
# JSON 数组：禁止新开仓的交易对，例如 ["DOGEUSDT","1000PEPEUSDT"]。
RISK_BLOCKED_SYMBOLS=[]
# JSON 对象：单品种覆盖限制，例如 {"BTCUSDT":{"max_leverage":3,"max_position_value":500}}。
RISK_SYMBOL_OVERRIDES={}
# UTC 允许交易的半开区间 [start, end)；0 和 24 = 全天。
RISK_TRADING_START_HOUR_UTC=0
RISK_TRADING_END_HOUR_UTC=24

# ─── LLM 决策白名单（可选） ──────────────────────────────
# Restricts which symbols the LLM may decide to trade on. Empty (default)
# means no restriction — the LLM can decide on any symbol it sees.
# Set as a JSON list to limit, e.g.:
#   LLM_ALLOWED_SYMBOLS=["BTCUSDT","ETHUSDT","SOLUSDT"]
LLM_ALLOWED_SYMBOLS=

# ─── API 鉴权（可选） ─────────────────────────────────────
# Set this to require `Authorization: Bearer <key>` on dangerous endpoints
# (kill-switch, order placement, position close, etc.). Leave empty to keep
# the existing localhost-only workflow where any local client can call the API.
# Generate a random value, e.g. `python -c "import secrets; print(secrets.token_urlsafe(32))"`
AUTH_API_KEY=

# ─── 告警外发（可选） ─────────────────────────────────────
# 至少填一个 URL 才能外发。空 = 该 provider 关闭。
# 详细配置见 docs/alerts.md
ALERT_FEISHU_WEBHOOK=
ALERT_DINGTALK_WEBHOOK=
ALERT_WECOM_WEBHOOK=
# 过滤阈值：info | warning | error | critical
ALERT_MIN_LEVEL=warning
# HTTP 超时（秒）
ALERT_HTTP_TIMEOUT=10

# ─── Telegram 监控 Bot（可选） ─────────────────────────────
# 启用条件：bot_enabled=true  +  提供 bot_telegram_token。
# 详细配置见 docs/bot.md
BOT_ENABLED=false
BOT_TELEGRAM_TOKEN=
# 允许触发命令的 chat id，CSV。留空 = 任何 chat id 都可触发（仅警告）
BOT_ALLOWED_CHAT_IDS=
# Bot 调用 API 的地址（默认指向本机 FastAPI）
BOT_API_BASE_URL=http://127.0.0.1:8000
# Bot 调用 API 的鉴权 key；留空 = 复用 AUTH_API_KEY
BOT_API_KEY=
# Bot 轮询事件流的间隔（秒）
BOT_EVENT_POLL_INTERVAL_SECONDS=5
# Bot 调 API 的超时（秒）
BOT_REQUEST_TIMEOUT_SECONDS=10
# 每日报告：到点推日报；时区为服务器本地时间
BOT_DAILY_REPORT_ENABLED=true
BOT_DAILY_REPORT_HOUR=0
BOT_DAILY_REPORT_MINUTE=5
# 静默时段，"22-8" 表示 22:00–08:00 期间 WARNING 级别压下；
# CRITICAL / ERROR 始终外发。
BOT_QUIET_HOURS=
# 主动告警：低于此级别的 alert 静默。info | warning | error | critical
BOT_MIN_ALERT_LEVEL=warning
# 同 fingerprint alert 的冷却秒数（防止刷屏）
BOT_ALERT_FINGERPRINT_COOLDOWN_SECONDS=300
# 单聊每秒最多发几条（Telegram rate limit）
BOT_SEND_RATE_PER_SECOND=4
# scope 头：标识该请求来自 bot，access log 中会带 X-Bot-Scope
BOT_OUTBOUND_SCOPE=monitor
# 无人值守 Bot 多周期分析（默认仅分析 + 告警；绝不默认自动下单）
# 必须先同时确认 BOT_AUTOPILOT_ENABLED=true 与 BOT_AUTOPILOT_LIVE_ORDER_ENABLED=true，
# 并且 ENABLE_LIVE_TRADING=true、Kill Switch 关闭、账户对账正常，才可能向交易所提交订单。
BOT_AUTOPILOT_ENABLED=false
BOT_AUTOPILOT_LIVE_ORDER_ENABLED=false
BOT_AUTOPILOT_EXCHANGE=binance_usdm
# CSV；留空时只分析 DEFAULT_SYMBOL
BOT_AUTOPILOT_SYMBOLS=
# 每轮分析间隔（秒），范围 60–3600
BOT_AUTOPILOT_CYCLE_SECONDS=300
# 1h、5h、24h 每个窗口都至少需要达到的绝对涨跌阈值；0.002 = 0.2%
BOT_AUTOPILOT_MIN_RETURN_PCT=0.002
# Bot 专属名义金额上限（USDT）；仍会受 MAX_POSITION_VALUE 与统一风控约束
BOT_AUTOPILOT_MAX_ORDER_NOTIONAL=25
BOT_AUTOPILOT_MAX_DAILY_NOTIONAL=100
